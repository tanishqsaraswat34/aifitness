# AI Fitness Assistant - Environment Variables

# Gemini API Key (for chat and meal suggestions)
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud API Key (for speech-to-text and text-to-speech)
# Get it from: https://console.cloud.google.com/
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# Flask secret key (for session management)
FLASK_SECRET_KEY=your-secret-key-change-this-in-production

# Database (optional, for future use)
DATABASE_PATH=fitness_app.db

# Environment
FLASK_ENV=development
